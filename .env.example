# Open Brain Configuration
# Copy this file to .env and fill in your actual credentials.

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Optional: restrict bot to a single chat (get your chat ID by messaging @userinfobot)
# TELEGRAM_AUTHORIZED_CHAT_ID=

# --- PostgreSQL Database ---
POSTGRES_USER=openbrain
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_DB=openbrain_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- LLM Configuration (OpenRouter recommended) ---
# Shared API key and base URL for all models
# Get your key at https://openrouter.ai/keys
LLM_API_KEY=sk-or-v1-your_key_here
LLM_BASE_URL=https://openrouter.ai/api/v1

# --- Model Roles ---
# Assign a different model to each task type (OpenRouter format: provider/model-name)
# Text: cheap & fast for categorization, extraction, simple chat
MODEL_TEXT=moonshotai/kimi-k2.5
# Reasoning: complex analysis, answering nuanced questions, research
MODEL_REASONING=anthropic/claude-sonnet-4.6
# Coding: code generation, debugging, technical analysis
MODEL_CODING=minimax/minimax-m2.5
# Vision: image recognition, OCR, invoice/receipt parsing (must be multimodal)
MODEL_VISION=moonshotai/kimi-k2.5
# Embedding: vector embeddings for semantic search
MODEL_EMBEDDING=openai/text-embedding-3-small

# --- Per-role overrides (optional, leave blank to use shared LLM_API_KEY/LLM_BASE_URL) ---
# MODEL_TEXT_API_KEY=
# MODEL_TEXT_BASE_URL=
# MODEL_REASONING_API_KEY=
# MODEL_REASONING_BASE_URL=
# MODEL_CODING_API_KEY=
# MODEL_CODING_BASE_URL=
# MODEL_VISION_API_KEY=
# MODEL_VISION_BASE_URL=

# --- Speech-to-Text (Voice Note Transcription) ---
# Provider: "openai" (default), "local" (openai-whisper), "groq"
STT_PROVIDER=openai
# Required for STT_PROVIDER=openai (direct OpenAI key, NOT OpenRouter)
# OPENAI_API_KEY=sk-your_openai_key_here
# Required for STT_PROVIDER=groq (free tier available at https://console.groq.com)
# GROQ_API_KEY=gsk_your_groq_key_here
# For STT_PROVIDER=local: model size (tiny, base, small, medium, large)
# WHISPER_MODEL_SIZE=base

# --- MCP Server ---
# MCP_TRANSPORT=stdio   # "stdio" for local MCP clients, "sse" for network access
# MCP_PORT=3100         # Port for SSE transport
